# Backend API base URL (defaults to same-origin relative path)
# For local development:
VITE_API_BASE_URL=http://localhost:3000
# For production (Render backend):
# VITE_API_BASE_URL=https://mon-0ots.onrender.com

# WebSocket base URL (optional - will be derived from VITE_API_BASE_URL if omitted)
# For local development:
VITE_WS_BASE_URL=ws://localhost:3000
# For production (Render backend):
# VITE_WS_BASE_URL=wss://mon-0ots.onrender.com
